# Copy this file to .env.local and fill in the values
# .env.local is gitignored - never commit secrets

# ──────────────────────────────────────────────────────
# Supabase (auth, db, storage, realtime)
# ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJh...your-service-key
DATABASE_URL=postgresql://postgres:password@db.YOUR_PROJECT.supabase.co:5432/postgres

# ──────────────────────────────────────────────────────
# Google OAuth
# - Login scope: openid email profile (for Supabase Auth, Phase 1)
# - Drive scope: drive.readonly (for content import pipeline, Pre-Sprint+)
#   Run `pnpm drive:auth` once to get GOOGLE_REFRESH_TOKEN.
# ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET
GOOGLE_REFRESH_TOKEN=1//...your-refresh-token

# ──────────────────────────────────────────────────────
# Google Gemini (single AI provider: generation + classification + embeddings)
# One key from Google AI Studio: https://aistudio.google.com/apikey
# ──────────────────────────────────────────────────────
GEMINI_API_KEY=
# Models in use:
#   - gemini-2.5-pro    (lesson + question generation, scenario grading)
#   - gemini-2.5-flash  (topic/scope classification)
#   - gemini-embedding-001 (RAG embeddings)
GEMINI_MODEL_GENERATION=gemini-2.5-pro
GEMINI_MODEL_CLASSIFICATION=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ──────────────────────────────────────────────────────
# ElevenLabs (TTS - 4 Hebrew voices)
# ──────────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_YOAV=VOICE_ID_HERE
ELEVENLABS_VOICE_TALI=VOICE_ID_HERE
ELEVENLABS_VOICE_MICHAL=VOICE_ID_HERE
ELEVENLABS_VOICE_ORI=VOICE_ID_HERE

# ──────────────────────────────────────────────────────
# Inngest (async jobs)
# ──────────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ──────────────────────────────────────────────────────
# Email (Resend for transactional / magic link)
# ──────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=hello@studibuilder.app

# ──────────────────────────────────────────────────────
# Sentry (observability)
# ──────────────────────────────────────────────────────
SENTRY_DSN=https://...@...ingest.sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=studibuilder
SENTRY_PROJECT=studibuilder-web

# ──────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
